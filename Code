        if self._log_panel_visible:
            self._log_panel.pack_forget()
            self._log_panel_visible=False
            self._log_icon_open=False
            self._draw_log_icon()
        else:
            self._log_panel.pack(fill="x",padx=20,pady=(0,6),after=self._btn.master.master)
            self._log_panel_visible=True
            self._log_icon_open=True
            self._draw_log_icon()
            self._log_panel.config(state="normal")
            self._log_panel.delete("1.0","end")
            for line in self._log_lines[-100:]:
                self._log_panel.insert("end", line+"\n")
            self._log_panel.see("end")
            self._log_panel.config(state="disabled")

