    def _row(self,parent,label,key):
        C,D,F,A=self.CARD,self.DIM,self.FG,self.ACC
        r=tk.Frame(parent,bg=C); r.pack(fill="x",pady=2)
        tk.Label(r,text=label,bg=C,fg=D,font=("Consolas",9),width=13,anchor="w").pack(side="left")
        var=tk.StringVar(value=self.cfg.get(key,""))
        self._vars[key]=var
        lbl=tk.Label(r,textvariable=var,bg=self.ENT,fg=F,font=("Consolas",10),width=10,relief="flat",cursor="hand2",highlightthickness=1,highlightbackground="#2a2a35",highlightcolor=A)
        lbl.pack(side="right"); lbl.bind("<Button-1>",lambda e,v=var,l=lbl,k=key:self._listen(v,l,k,e))

    def _listen(self,var,lbl,key,event):
        self._cancel(None); self._lv=var; self._ll=lbl; self._lk=key
        lbl.config(fg=self.ACC2,highlightbackground=self.ACC2); var.set("Press a key...")
        self._kh=keyboard.on_press(self._got_key,suppress=False); return "break"

    def _got_key(self,event):
        if not self._lv: return
        km={f"f{i}":f"F{i}" for i in range(1,13)}
        name=km.get(event.name.lower(),event.name)
        self._lv.set(name); self.cfg[self._lk]=name
        if self._ll: self._ll.config(fg=self.FG,highlightbackground="#2a2a35")
        try: keyboard.unhook(self._kh)
        except: pass
        self._lv=self._ll=self._lk=None; self.after(100,self._rebind)

    def _cancel(self,e):
        if not self._lv: return
        self._lv.set(self.cfg.get(self._lk,""))
        if self._ll: self._ll.config(fg=self.FG,highlightbackground="#2a2a35")
        try: keyboard.unhook(self._kh)
        except: pass
        self._lv=self._ll=self._lk=None

    def _pick(self,key):
        if self._picking: return
        self._picking=True; self._pick_target=key
        lbl=self._pix_labels[key]
        self.attributes("-topmost",True)
        self._status_line.config(text=f"Hover over target — capturing in 3s...")
        lbl.config(text="3...",fg=self.ACC2)
        self.after(1000,lambda:lbl.config(text="2..."))
        self.after(2000,lambda:lbl.config(text="1..."))
        self.after(3000,lambda:(self._do_pick(),self.attributes("-topmost",False)))

    def _do_pick(self):
        key=self._pick_target
        x,y=pyautogui.position()
        c=sample(x,y); b=bright(c)
        if "_" in key:
            self.cfg[f"{key}_x"]=x; self.cfg[f"{key}_y"]=y
        else:
            self.cfg[f"{key}x"]=x; self.cfg[f"{key}y"]=y
        lbl=self._pix_labels[key]
        lbl.config(text=f"({x},{y}) b={b}",fg=self.ACC)
        self._log(f"Picked {key}: ({x},{y}) b={b}")
        self._picking=False; self._pick_target=None

    def _auto_thresh(self):
        x,y=self.cfg.get("s1x",0),self.cfg.get("s1y",0)
        if x==0: self._log("Pick Skill 1 first!"); return
        b=bright(sample(x,y)); thresh=max(50,int(b*0.5))
        self._thresh.set(str(thresh)); self.cfg["ready_thresh"]=thresh
        self._log(f"Auto threshold: {thresh} (skill 1 b={b})")

    def _gather(self):
        s=dict(self.cfg)
        for k,v in self._vars.items(): s[k]=v.get().strip()
        s["use_m1"]=self._m1.get()
        s["m1_speed"]=int(self._m1_speed.get())
        s["use_m2"]=self._m2.get()
        try: s["m2_cd"]=float(self._m2_cd.get())
        except: s["m2_cd"]=5.0
        s["auto_jump"]=self._jump.get()
        s["auto_mode"]=self._automode.get()
        s["auto_move"]=self._automove.get()
        s["afk_aim"]=self._afkAim.get()
        s["aim_power"]=int(self._aim_power.get())
        s["hold_skills_base"]=self._hold_skills_base.get()
        s["hold_time_base"]=self._hold_time_base.get()
        s["hold_skills_mode"]=self._hold_skills_mode.get()
        s["hold_time_mode"]=self._hold_time_mode.get()
        s["anti_afk"]=self._anti_afk.get()
        for k in ["afk_play","afk_chars_btn","afk_next","afk_char","afk_select"]:
            s[f"{k}_x"]=self.cfg.get(f"{k}_x",0); s[f"{k}_y"]=self.cfg.get(f"{k}_y",0)
        try: s["afk_char_page"]=int(self._afk_page.get())
        except: s["afk_char_page"]=0
        s["overlay_opacity"]=self._ov_opacity.get()
        s["sounds_enabled"]=self._sounds.get()
        s["combos"]=self._combos.get()
        try: s["combo_delay"]=float(self._combo_delay.get())
        except: s["combo_delay"]=0.5
        try: s["skip_time"]=float(self._skip_time.get())
        except: s["skip_time"]=7.0
        try: s["ready_thresh"]=int(self._thresh.get())
        except: pass
        return s

    def _save(self):
        self.cfg=self._gather(); save_cfg(self.cfg)
        self._log("Settings saved."); self._rebind()

    def _toggle(self):
        if self.eng.running:
            self.eng.stop()
            self._test_running=False
        else: self.cfg=self._gather(); self.eng.cfg=self.cfg; self.eng.start(self.cfg)

    def _rebind(self):
        try: keyboard.unhook_all_hotkeys()
        except: pass
        time.sleep(0.05)
        s=self._gather(); res=[]
        for key,fn in [(s["start_key"],lambda:self.after(0,self._toggle)),(s["stop_key"],lambda:self.after(0,self.eng.stop)),(s["close_key"],lambda:os._exit(0))]:
            try: keyboard.add_hotkey(key,fn,suppress=False); res.append(f"✓{key}")
            except: res.append(f"✗{key}")
        self._log("Keys: "+"  ".join(res))

    def _log(self,msg):
        self._log_lines.append(msg)
        if len(self._log_lines)>500: self._log_lines=self._log_lines[-300:]
        def _do():
            self._status_line.config(text=msg[:80])
            if self._log_panel_visible:
                self._log_panel.config(state="normal")
                self._log_panel.insert("end", msg+"\n")
                self._log_panel.see("end")
                self._log_panel.config(state="disabled")
            if hasattr(self,"_overlay_action") and self._overlay and self._overlay.winfo_exists():
                self._overlay_action.config(text=msg[:35])
        self.after(0,_do)

