    def _test_afk_clicks(self):
        """Test each Anti-AFK position — actually clicks each one. Stops if macro is stopped."""
        self._test_running=True
        def _run():
            for i in range(5, 0, -1):
                if not self._test_running: self._log("Test cancelled"); return
                self._log(f"Test starting in {i}s — switch to Roblox!")
                time.sleep(1.0)
            import ctypes as _ct
            class PT(_ct.Structure):
                _fields_=[("x",_ct.c_long),("y",_ct.c_long)]
            def _glide_t(x, y):
                pt=PT(); _ct.windll.user32.GetCursorPos(_ct.byref(pt))
                tdx=int(x)-pt.x; tdy=int(y)-pt.y; ax=ay=0.0
                for i in range(1,46):
                    t=i/45; e=t*t*(3-2*t); nx=tdx*e; ny=tdy*e
                    dx=int(nx-ax); dy=int(ny-ay)
                    if dx or dy: _ct.windll.user32.mouse_event(0x0001,dx,dy,0,0)
                    ax=nx; ay=ny; time.sleep(0.011)
                pt2=PT(); _ct.windll.user32.GetCursorPos(_ct.byref(pt2))
                fx=int(x)-pt2.x; fy=int(y)-pt2.y
                if fx or fy: _ct.windll.user32.mouse_event(0x0001,fx,fy,0,0); time.sleep(0.01)
                # Jitter to register hover
                _ct.windll.user32.mouse_event(0x0001, 1, 0, 0, 0); time.sleep(0.008)
                _ct.windll.user32.mouse_event(0x0001, -1, 0, 0, 0)
            def _click_t(x, y):
                _ct.windll.user32.SetCursorPos(int(x), int(y)-80); time.sleep(0.2)
                _glide_t(x, y); time.sleep(0.15)
                # Wiggle to reinforce hover
                for _ in range(3):
                    _ct.windll.user32.mouse_event(0x0001, 2, 0, 0, 0); time.sleep(0.02)
                    _ct.windll.user32.mouse_event(0x0001, -2, 0, 0, 0); time.sleep(0.02)
                time.sleep(0.1)
                class _MI(_ct.Structure):
                    _fields_=[("dx",_ct.c_long),("dy",_ct.c_long),("mouseData",_ct.c_ulong),
                              ("dwFlags",_ct.c_ulong),("time",_ct.c_ulong),("dwExtraInfo",_ct.POINTER(_ct.c_ulong))]
                class _INP(_ct.Structure):
                    _fields_=[("type",_ct.c_ulong),("mi",_MI)]
                _ct.windll.user32.SendInput(1,_ct.byref(_INP(0,_MI(0,0,0,0x0002,0,None))),_ct.sizeof(_INP))
                time.sleep(0.12)
                _ct.windll.user32.SendInput(1,_ct.byref(_INP(0,_MI(0,0,0,0x0004,0,None))),_ct.sizeof(_INP))
            steps = [("afk_play","PLAY"),("afk_chars_btn","CHARACTERS"),("afk_next","NEXT"),
                     ("afk_char","CHARACTER"),("afk_select","SELECT")]
            for key, name in steps:
                if not self._test_running: self._log("Test cancelled"); return
                x=self.cfg.get(f"{key}_x",0); y=self.cfg.get(f"{key}_y",0)
                if x==0:
                    self._log(f"Test: {name} — not set, skipping"); time.sleep(1.0); continue
                self._log(f"Test: clicking {name} ({x},{y})...")
                _click_t(x, y)
                time.sleep(3.0)
            self._log("Test complete!")
            self._test_running=False
        threading.Thread(target=_run, daemon=True).start()

    def _export_cfg(self):
        """Export settings to a file."""
        import tkinter.filedialog as fd
        path = fd.asksaveasfilename(
            parent=self, title="Export Settings",
            defaultextension=".json", filetypes=[("JSON files","*.json")],
            initialfile="aba_settings_export.json"
        )
        if not path: return
        try:
            s = self._gather()
            with open(path, "w") as f:
                json.dump(s, f, indent=2)
            self._log(f"Exported to {os.path.basename(path)}")
        except Exception as e:
            self._log(f"Export failed: {e}")

    def _import_cfg(self):
        """Import settings from a file."""
        import tkinter.filedialog as fd, tkinter.messagebox as mb
        path = fd.askopenfilename(
            parent=self, title="Import Settings",
            filetypes=[("JSON files","*.json")]
        )
        if not path: return
        try:
            with open(path) as f:
                d = json.load(f)
            self.cfg.update(d)
            save_cfg(self.cfg)
            mb.showinfo("Import Done", "Settings imported!\nRestart to apply all changes.", parent=self)
            self._log(f"Imported from {os.path.basename(path)}")
        except Exception as e:
            self._log(f"Import failed: {e}")

    def _tick_session(self):
        """Update session timer every second."""
        if self.eng.running and self._session_start:
            elapsed = int(time.time() - self._session_start)
            m, s = divmod(elapsed, 60)
            h, m = divmod(m, 60)
            if h > 0:
                self._session_lbl.config(text=f"⏱ {h}:{m:02d}:{s:02d}")
            else:
                self._session_lbl.config(text=f"⏱ {m}:{s:02d}")
        else:
            self._session_lbl.config(text="")
        self.after(1000, self._tick_session)

    def _set_status(self,active):
        def _do():
            if active:
                self._dot.config(fg="#e8384f"); self._slbl.config(fg=self.FG,text="  ACTIVE"); self._btn.config(text="STOP",bg="#333340")
                if not self._session_start: self._session_start = time.time()
            else:
                self._dot.config(fg="#2a2a35"); self._slbl.config(fg=self.DIM,text="  OFFLINE"); self._btn.config(text="START",bg=self.ACC)
                self._session_start = None
            if hasattr(self,"_overlay") and self._overlay and self._overlay.winfo_exists():
                col=self.ACC if active else self.DIM
                self._overlay_dot.config(fg=col)
                self._overlay_lbl.config(text="ACTIVE" if active else "OFFLINE",fg=col)
                self._overlay_toggle.config(text="STOP" if active else "START",
                    bg=self.CARD if active else self.ACC)
        self.after(0,_do)

    def _close(self):
        self.eng.stop(); save_cfg(self._gather()); self.destroy(); sys.exit(0)

if __name__=="__main__":
    App().mainloop()
