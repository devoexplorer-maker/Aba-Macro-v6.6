# ── ENGINE ─────────────────────────────────────────────────────
class Engine:
    def __init__(self):
        self.running=False; self.log_cb=None; self.status_cb=None; self.cfg=None
        self.afk_busy=False  # True while Anti-AFK is clicking buttons

    def start(self, cfg):
        if self.running: return
        self.cfg=cfg; self.running=True
        threading.Thread(target=self._afk_loop, daemon=True).start()
        if cfg.get("sounds_enabled",True): play_sound("start")
        if cfg.get("s1x",0)==0:
            self.log("⚠ Calibrate skill pixels first! (SETUP section)")
        else:
            threading.Thread(target=self._loop, daemon=True).start()
        if self.status_cb: self.status_cb(True)

    def stop(self):
        was_running = self.running
        self.running=False
        if was_running and self.cfg and self.cfg.get("sounds_enabled",True): play_sound("stop")
        if self.status_cb: self.status_cb(False)

    def log(self, m):
        if self.log_cb: self.log_cb(m)

    def _afk_loop(self):
        """Anti-AFK v2 — detects ABA menu screen, rejoins game.
        Works on: title screen (PLAY visible) AND lobby/new-server screen.
        Click method: glide cursor to button via relative mouse_event, then
        single mousedown+mouseup. For CHARACTERS toggle: use screen-state
        detection to ensure panel is open before proceeding."""
        import ctypes as _ct

        LEFTDOWN = 0x0002
        LEFTUP   = 0x0004

        class PT(_ct.Structure):
            _fields_=[("x",_ct.c_long),("y",_ct.c_long)]

        def _focus_roblox():
            """Bring Roblox to foreground."""
            try:
                import subprocess
                si = subprocess.STARTUPINFO()
                si.dwFlags |= subprocess.STARTF_USESHOWWINDOW
                si.wShowWindow = 0  # SW_HIDE
                subprocess.run(
                    ['powershell','-Command',
                     '(Get-Process -Name RobloxPlayerBeta -ErrorAction SilentlyContinue | Select-Object -First 1).MainWindowHandle | ForEach-Object { [void][System.Runtime.InteropServices.Marshal]::GetLastWin32Error(); Add-Type -Name W -Namespace X -MemberDefinition \'[DllImport("user32.dll")] public static extern bool SetForegroundWindow(IntPtr h);\'; [X.W]::SetForegroundWindow($_) }'],
                    capture_output=True, timeout=3,
                    startupinfo=si,
                    creationflags=0x08000000  # CREATE_NO_WINDOW
                )
            except:
                pass
            time.sleep(0.3)

        def _glide(x, y):
            """Smooth relative mouse_event glide from current pos to (x,y).
            Returns True if cursor ended within 3px of target."""
            pt=PT(); _ct.windll.user32.GetCursorPos(_ct.byref(pt))
            tdx = int(x) - pt.x
            tdy = int(y) - pt.y
            steps = 45
            ax, ay = 0.0, 0.0
            for i in range(1, steps+1):
                t = i / steps
                e = t * t * (3 - 2 * t)
                nx = tdx * e; ny = tdy * e
                dx = int(nx - ax); dy = int(ny - ay)
                if dx or dy:
                    _ct.windll.user32.mouse_event(0x0001, dx, dy, 0, 0)
                ax = nx; ay = ny
                time.sleep(0.011)
            # Correction — close rounding gap
            pt2=PT(); _ct.windll.user32.GetCursorPos(_ct.byref(pt2))
            fix_dx = int(x) - pt2.x; fix_dy = int(y) - pt2.y
            if fix_dx or fix_dy:
                _ct.windll.user32.mouse_event(0x0001, fix_dx, fix_dy, 0, 0)
                time.sleep(0.01)
            # Jitter to prove alive
            _ct.windll.user32.mouse_event(0x0001, 1, 0, 0, 0)
            time.sleep(0.008)
            _ct.windll.user32.mouse_event(0x0001, -1, 0, 0, 0)
            # Verify
            pt3=PT(); _ct.windll.user32.GetCursorPos(_ct.byref(pt3))
            return abs(pt3.x - int(x)) <= 3 and abs(pt3.y - int(y)) <= 3

        def _raw_click():
            """Single click via SendInput at current cursor position."""
            class _MI(_ct.Structure):
                _fields_=[("dx",_ct.c_long),("dy",_ct.c_long),
                          ("mouseData",_ct.c_ulong),("dwFlags",_ct.c_ulong),
                          ("time",_ct.c_ulong),("dwExtraInfo",_ct.POINTER(_ct.c_ulong))]
            class _INP(_ct.Structure):
                _fields_=[("type",_ct.c_ulong),("mi",_MI)]
            # Mouse down
            _ct.windll.user32.SendInput(1, _ct.byref(_INP(0, _MI(0,0,0,0x0002,0,None))), _ct.sizeof(_INP))
            time.sleep(0.12)
            # Mouse up
            _ct.windll.user32.SendInput(1, _ct.byref(_INP(0, _MI(0,0,0,0x0004,0,None))), _ct.sizeof(_INP))

        def _click_at(x, y, after=1.0):
            """Position cursor 80px above, glide to target, single click."""
            _ct.windll.user32.SetCursorPos(int(x), int(y) - 80)
            time.sleep(0.2)
            ok = _glide(x, y)
            time.sleep(0.1)
            if not ok:
                pass  # silently correct
                _ct.windll.user32.SetCursorPos(int(x), int(y))
                time.sleep(0.05)
                _ct.windll.user32.mouse_event(0x0001, 1, 1, 0, 0)
                time.sleep(0.02)
                _ct.windll.user32.mouse_event(0x0001, -1, -1, 0, 0)
                time.sleep(0.1)
            _raw_click()
            time.sleep(after)

        def _click_at_toggle(x, y, after=1.0):
            """Same as _click_at but moves cursor FAR away immediately after click.
            Prevents any phantom double-click from hitting the same button."""
            _ct.windll.user32.SetCursorPos(int(x), int(y) - 80)
            time.sleep(0.2)
            ok = _glide(x, y)
            time.sleep(0.1)
            if not ok:
                pass  # silently correct
                _ct.windll.user32.SetCursorPos(int(x), int(y))
                time.sleep(0.05)
                _ct.windll.user32.mouse_event(0x0001, 1, 1, 0, 0)
                time.sleep(0.02)
                _ct.windll.user32.mouse_event(0x0001, -1, -1, 0, 0)
                time.sleep(0.1)
            _raw_click()
            # Immediately yank cursor away so no phantom second click hits the button
            time.sleep(0.05)
            _ct.windll.user32.SetCursorPos(10, 10)
            time.sleep(after)

        def _is_screen_dark(sw, sh):
            """Check if center of screen is dark (character panel overlay)."""
            return bright(sample(sw//2, sh//2)) < 40

        def _is_play_visible(cfg):
            """Detect the green PLAY button on ABA menu.
            Samples 20 points across the button area. The button is a wide green rectangle.
            Points spread wide to catch the green background even if calibrated on the text."""
            px=cfg.get("afk_play_x",0); py=cfg.get("afk_play_y",0)
            if px==0: return False
            hits = 0
            offsets = [
                # Horizontal spread across the button (text is center, green is edges)
                (-60,0),(-45,0),(-30,0),(-15,0),(0,0),(15,0),(30,0),(45,0),(60,0),
                # Vertical spread (above and below text)
                (-30,-15),(0,-15),(30,-15),
                (-30,15),(0,15),(30,15),
                # Corners of button
                (-50,-12),(50,-12),(-50,12),(50,12),
            ]
            for ox,oy in offsets:
                c = sample(px+ox, py+oy)
                # Green: G dominant — covers bright green (0,200,0) and darker greens
                if c[1]>100 and c[1]>c[0]+30 and c[1]>c[2]+30:
                    hits += 1
            return hits >= 10

        # ── MAIN LOOP ──
        _afk_tick = 0
        while self.running:
            try:
                cfg = self.cfg
                if not cfg.get("anti_afk", False):
                    time.sleep(1.0); continue

                missing = [k for k in ["afk_play","afk_chars_btn","afk_char","afk_select"]
                           if cfg.get(f"{k}_x",0)==0]
                if missing:
                    self.log(f"Anti-AFK missing: {', '.join(missing)}")
                    time.sleep(3.0); continue

                # Only trigger on ABA menu — check for green PLAY button pattern
                _afk_tick += 1
                play_found = _is_play_visible(cfg)
                if _afk_tick % 5 == 0:
                    self.log(f"AFK scan: play={'YES' if play_found else 'no'}")
                if not play_found:
                    time.sleep(1.5); continue

                self.log(">> ABA menu detected — rejoining...")
                self.afk_busy=True
                if cfg.get("sounds_enabled",True): play_sound("afk")
                _focus_roblox()
                sw=_ct.windll.user32.GetSystemMetrics(0)
                sh=_ct.windll.user32.GetSystemMetrics(1)

                if not self.running: continue

                # ── STEP 1: PLAY ──────────────────────────────────
                # Safe to retry — PLAY is a one-way button (not a toggle)
                self.log(">> Step 1: PLAY")
                px2=cfg.get("afk_play_x",0); py2=cfg.get("afk_play_y",0)
                play_done = False
                for att in range(3):
                    if not self.running: break
                    _click_at(px2, py2, after=1.5)
                    # Wait for PLAY button to disappear (green gone)
                    t0=time.time()
                    while time.time()-t0 < 4.0:
                        if not _is_play_visible(cfg):
                            play_done=True; break
                        time.sleep(0.3)
                    if play_done:
                        self.log(f"  PLAY clicked! (att {att+1})")
                        break
                    self.log(f"  PLAY miss att {att+1}")
                if not play_done:
                    self.log("  PLAY failed — will retry next cycle")
                    self.afk_busy=False
                    time.sleep(3.0); continue
                time.sleep(3.0)  # wait for lobby to load

                if not self.running: continue

                # ── STEP 2: CHARACTERS (toggle button — EXACTLY 1 click) ──
                self.log(">> Step 2: CHARACTERS")
                cx=cfg.get("afk_chars_btn_x",0); cy=cfg.get("afk_chars_btn_y",0)
                before_b = bright(sample(sw//2, sh//2))

                # One click — then cursor yanked away to prevent phantom double
                _click_at_toggle(cx, cy, after=1.5)

                # Check if panel opened (screen gets darker from overlay)
                after_b = bright(sample(sw//2, sh//2))
                panel_open = after_b < before_b - 12

                if not panel_open:
                    # Click didn't register. Try once more.
                    self.log("  chars didn't open — retry once")
                    time.sleep(1.5)
                    before_b2 = bright(sample(sw//2, sh//2))
                    _click_at_toggle(cx, cy, after=1.5)
                    after_b2 = bright(sample(sw//2, sh//2))
                    panel_open = after_b2 < before_b2 - 12

                if not panel_open:
                    self.log("  chars failed — abort, will retry next cycle")
                    self.afk_busy=False
                    time.sleep(3.0); continue

                self.log("  chars panel open!")
                time.sleep(1.0)

                if not self.running: continue

                # ── STEP 3: NEXT pages (if needed) ────────────────
                pages = int(cfg.get("afk_char_page",0))
                if pages > 0:
                    self.log(f">> Step 3: NEXT x{pages}")
                    nx2=cfg.get("afk_next_x",0); ny2=cfg.get("afk_next_y",0)
                    for pg in range(pages):
                        if not self.running: break
                        self.log(f"  NEXT {pg+1}/{pages}")
                        _click_at(nx2, ny2, after=2.0)

                if not self.running: continue

                # ── STEP 4: CHARACTER portrait ────────────────────
                self.log(">> Step 4: Character")
                _click_at(cfg.get("afk_char_x",0), cfg.get("afk_char_y",0), after=1.5)

                if not self.running: continue

                # ── STEP 5: SELECT ────────────────────────────────
                self.log(">> Step 5: SELECT")
                _click_at(cfg.get("afk_select_x",0), cfg.get("afk_select_y",0), after=1.0)

                self.log(">> Done! Loading into game...")
                time.sleep(10.0)
                self.afk_busy=False

            except Exception as e:
                self.log(f"AFK error: {e}")
                self.afk_busy=False
                time.sleep(3.0)

    def _loop(self):
        cfg = self.cfg
        thresh = cfg.get("ready_thresh",30)
        pts = [(cfg["s1x"],cfg["s1y"]),(cfg["s2x"],cfg["s2y"]),
               (cfg["s3x"],cfg["s3y"]),(cfg["s4x"],cfg["s4y"])]
        mx,my = cfg["modex"],cfg["modey"]

        self.log("=== STARTED ===")
        _last_m2 = 0.0
        for i,(x,y) in enumerate(pts):
            self.log(f"S{i+1} ({x},{y}) b={bright(sample(x,y))} | thresh={thresh}")

        last_press = [0.0]*4
        stuck_count = [0]*4
        skip_until = [0.0]*4
        MIN_REPRESS = 0.3
        MAX_STUCK = 2
        SKIP_TIME = float(cfg.get("skip_time",7.0))
        tick = 0

        while self.running:
            now = time.time()

            # Auto Mode (PRESS G) — white pixel at mode bar + not sky
            if cfg.get("auto_mode",True) and mx > 0:
                mc = sample(mx, my)
                if mc[0]>220 and mc[1]>220 and mc[2]>220:
                    # Sky check — if 30px above is also white, it's sky not PRESS G
                    sky = sample(mx, my-30)
                    if not(sky[0]>220 and sky[1]>220 and sky[2]>220):
                        self.log(">> PRESS G!")
                        t0=time.time()
                        while self.running and time.time()-t0<10:
                            win_press('g',0.07); time.sleep(0.08)
                            mc2=sample(mx,my)
                            if not(mc2[0]>220 and mc2[1]>220 and mc2[2]>220):
                                self.log(">> Awakened!"); time.sleep(0.3); break
                        continue

            # Skip everything below if Anti-AFK is actively clicking
            if self.afk_busy:
                time.sleep(0.1); continue

            # All dark = not in game
            all_dark = all(bright(sample(x,y))<10 for x,y in pts)
            if all_dark:
                time.sleep(1.0); continue

            used = False
            if cfg.get("auto_move",True):
                for i,(x,y) in enumerate(pts):
                    if not self.running: break
                    b = bright(sample(x,y))
                    if now < skip_until[i]: continue
                    if stuck_count[i] >= MAX_STUCK:
                        skip_until[i]=now+SKIP_TIME; stuck_count[i]=0; continue
                    just_pressed = (now-last_press[i]) < MIN_REPRESS
                    if b>thresh and not just_pressed:
                        # Fire M2 first if enabled and CD elapsed
                        if cfg.get("use_m2",False) and i==0:
                            m2_cd = float(cfg.get("m2_cd",5.0))
                            if now - _last_m2 >= m2_cd:
                                import pyautogui as _pag
                                _pag.click(button="right")
                                time.sleep(0.1)
                                _last_m2 = now
                        key = str(i+1)
                        base_holds = [x.strip() for x in str(cfg.get("hold_skills_base","")).split(",") if x.strip()]
                        mode_holds = [x.strip() for x in str(cfg.get("hold_skills_mode","")).split(",") if x.strip()]
                        base_wait  = int(cfg.get("hold_time_base",0))
                        mode_wait  = int(cfg.get("hold_time_mode",0))
                        wait=0
                        if key in base_holds and base_wait>0: wait=base_wait
                        elif key in mode_holds and mode_wait>0: wait=mode_wait
                        win_press(key)
                        if wait>0:
                            self.log(f"Skill {i+1} — holding {wait}s"); time.sleep(wait)
                        # Combos
                        combos_raw = str(cfg.get("combos",""))
                        cdel = float(cfg.get("combo_delay",0.5))
                        for combo in combos_raw.split(";"):
                            combo=combo.strip()
                            if not combo or ":" not in combo: continue
                            trigger,chain=combo.split(":",1)
                            if trigger.strip()==key:
                                for ck in chain.split(","):
                                    ck=ck.strip()
                                    if ck: time.sleep(cdel); win_press(ck); self.log(f"  Combo: {ck}")
                        self.log(f"Skill {i+1} b={b}")
                        last_press[i]=now; stuck_count[i]+=1
                        time.sleep(0.12); used=True; break

            # Reset stuck when skill cools
            for i,(x,y) in enumerate(pts):
                if bright(sample(x,y))<thresh and now>=skip_until[i]:
                    stuck_count[i]=0

            if not used and self.running and not self.afk_busy:
                if cfg.get("use_m1",True):
                    m1_speed = int(cfg.get("m1_speed", 2))
                    if m1_speed >= 3:
                        # Speed 3 = rapid burst of 5 clicks
                        import ctypes as _ctm1
                        for _ in range(5):
                            _ctm1.windll.user32.mouse_event(0x0002, 0, 0, 0, 0)
                            time.sleep(0.02)
                            _ctm1.windll.user32.mouse_event(0x0004, 0, 0, 0, 0)
                            time.sleep(0.01)
                    elif m1_speed == 2:
                        # Speed 2 = triple click
                        for _ in range(3):
                            win_click(); time.sleep(0.015)
                    else:
                        win_click()
                if cfg.get("auto_jump",False):
                    import keyboard as _kb
                    _kb.press("space"); time.sleep(0.05); _kb.release("space")

            # AFK Rotate — spin camera (shift lock) via mouse_event
            if cfg.get("afk_aim",False) and not self.afk_busy:
                import ctypes as _ctr
                rotate_speed = cfg.get("aim_power", 2)
                if rotate_speed >= 5:
                    for _ in range(20):
                        _ctr.windll.user32.mouse_event(0x0001, 25, 0, 0, 0)
                        time.sleep(0.002)
                else:
                    # Speed 1=25, 2=50, 3=80, 4=110
                    dx = [25, 50, 80, 110][min(rotate_speed, 4) - 1]
                    _ctr.windll.user32.mouse_event(0x0001, dx, 0, 0, 0)

            tick+=1
            if tick%60==0:
                for i,(x,y) in enumerate(pts):
                    b=bright(sample(x,y))
                    self.log(f"  S{i+1} b={b} {'RDY' if b>thresh else 'CD'}")

            time.sleep(0.03)
        self.log("=== STOPPED ===")


